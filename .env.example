# Copy to .env and fill in. The .env file is gitignored — never commit real creds.

# SMTP connection
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
# Set to true only if you use port 465 (implicit TLS). 587 uses STARTTLS.
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Email envelope
# From shown to the recipient. Many providers require this to match SMTP_USER's domain.
MAIL_FROM=Sudbury Rides <bookings@yourdomain.com>
# Dispatch inbox that receives the booking emails.
MAIL_TO=dispatch@yourdomain.com

# Backend port (the Vite dev proxy expects 3001).
PORT=3001
